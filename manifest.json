{
  "manifest_version": 3,
  "name": "note フォロワーチェッカー",
  "version": "1.3",
  "description": "note.com のフォロワー差分を確認する",
  "permissions": ["storage"],
  "host_permissions": ["https://note.com/*"],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_page": "options.html",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "homepage_url": "https://github.com/licodeenar/note-follower-checker-addon",
  "background": {
    "service_worker": "background.js"
  }
}
